# App
PORT=5001
NODE_ENV=development
ACCESS_JWT_SECRET=access_jwt_secret_key_here
REFRESH_JWT_SECRET=refresh_jwt_secret_key_here
VERIFY_TOKEN_URL=http://localhost:5001/v1/rpc/auth/introspect

# Database
DATABASE_URL="postgres://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# MongoDB
MONGO_URI="mongodb+srv://[username]:[password]@[cluster-url].mongodb.net/smart_pos_logs?retryWrites=true&w=majority"

# Redis
REDIS_URL="rediss://default:[password]@[endpoint-url]:6379"

# RabbitMQ
RABBITMQ_URL="amqps://[user]:[password]@[host].cloudamqp.com/[vhost]"

# Mail
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-email-password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_FROM=your-email@gmail.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id

# Cloudinary
CLOUDINARY_URL=your-cloudinary-url-here

# API Payment Momo
MOMO_ENDPOINT =your-momo-endpoint-here
MOMO_PARTNER_CODE=your-momo-partner-code-here
MOMO_ACCESS_KEY=your-momo-access-key-here
MOMO_SECRET_KEY=your-momo-secret-key-here
MOMO_RETURN_URL=http://localhost:3000/payment/momo/return
MOMO_IPN_URL=http://localhost:5001/v1/rpc/payment/momo/notify

# API Payment ZaloPay
ZALOPAY_APP_ID=your-zalopay-app-id-here
ZALOPAY_KEY_1=your-zalopay-app-key-1-here
ZALOPAY_KEY_2=your-zalopay-app-key-2-here
ZALOPAY_ENDPOINT=https://openapi.zalopay.vn/v2/create
ZALOPAY_IPN_URL=http://localhost:5001/v1/rpc/payment/zalopay/notify
ZALOPAY_RETURN_URL=http://localhost:3000/payment/zalopay/return

# API Payment VNPay
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=your-vnpay-tmn-code-here
VNPAY_HASH_SECRET=your-vnpay-hash-secret-here
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay/return

